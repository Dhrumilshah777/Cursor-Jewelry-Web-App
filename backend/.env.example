PORT=5000
MONGODB_URI=mongodb://localhost:27017/jewelry-showcase
NODE_ENV=development

# JWT signing (user + admin sessions). Use a long random string in production.
JWT_SECRET=your-jwt-secret

# Optional: add these when you set up Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_ADMIN_EMAILS=you@example.com
# FRONTEND_URL=http://localhost:3000
# Public URL of this API (required for Google OAuth redirect; must match Google Console exactly).
# On Render you can omit BACKEND_URL if RENDER_EXTERNAL_URL is set (Render provides it).
# BACKEND_URL=https://your-api.onrender.com
# RENDER_EXTERNAL_URL is injected on Render — use BACKEND_URL to override when needed.

# Razorpay (test mode keys from Dashboard; add webhook URL and secret when going live)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=   # From Razorpay Dashboard > Settings > Webhooks (same secret for all events on that URL)
# On the same webhook URL, enable: payment.captured (order paid) and refund.processed (WhatsApp when refund settles to customer).

# Twilio — order SMS (from must be an SMS-capable Twilio number)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# WhatsApp order confirmation (Twilio Messages API). Sandbox: whatsapp:+14155238886 — user must join sandbox first.
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Twilio Verify — SMS OTP (Verify service must have SMS enabled; trial accounts can only send to verified numbers)
# TWILIO_VERIFY_SERVICE_SID=
# Optional: comma-separated 10-digit Indian numbers you verified in Twilio (trial) or any local you must always accept
# TWILIO_OTP_EXTRA_LOCAL_NUMBERS=9825251699,9825380155
