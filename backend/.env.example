PORT=5000
MONGODB_URI=mongodb://localhost:27017/jewelry-showcase
NODE_ENV=development

# Admin login (admin key only for now)
ADMIN_SECRET=your-secret-key

# Optional: add these when you set up Google OAuth later
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_ADMIN_EMAILS=you@example.com
# FRONTEND_URL=http://localhost:3000
# BACKEND_URL=http://localhost:5000
# JWT_SECRET=your-jwt-secret

# Razorpay (test mode keys from Dashboard; add webhook URL and secret when going live)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=   # From Razorpay Dashboard > Settings > Webhooks (required for payment.captured webhook)
