PORT=5000
MONGODB_URI=mongodb://localhost:27017/jewelry-showcase
NODE_ENV=development

# JWT signing (user + admin sessions). Use a long random string in production.
JWT_SECRET=your-jwt-secret

# Optional: add these when you set up Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_ADMIN_EMAILS=you@example.com
# FRONTEND_URL=http://localhost:3000
# BACKEND_URL=http://localhost:5000

# Razorpay (test mode keys from Dashboard; add webhook URL and secret when going live)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=   # From Razorpay Dashboard > Settings > Webhooks (required for payment.captured webhook)

# Twilio Verify — SMS OTP (Verify service must have SMS enabled; trial accounts can only send to verified numbers)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
